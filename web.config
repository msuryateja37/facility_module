<?xml version="1.0" encoding="utf-8"?>
<!--
  Azure App Service web.config
  Routes all requests through the Node.js / iisnode handler.
  The Express server serves the compiled Vite frontend from dist-server/public/.
-->
<configuration>
  <system.webServer>

    <handlers>
      <add name="iisnode"
           path="dist-server/index.js"
           verb="*"
           modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>
        <!-- Do not rewrite requests to node_modules -->
        <rule name="NodeInspector" patternSyntax="ECMAScript" stopProcessing="true">
          <match url="^dist-server\/index.js\/debug[\/]?" />
        </rule>

        <!-- Route all API calls to Express -->
        <rule name="API" stopProcessing="true">
          <match url="^api/.*" />
          <action type="Rewrite" url="dist-server/index.js" />
        </rule>

        <!-- Route static uploads -->
        <rule name="Uploads" stopProcessing="true">
          <match url="^uploads/.*" />
          <action type="Rewrite" url="dist-server/index.js" />
        </rule>

        <!-- All other requests → Express (which serves the Vite SPA) -->
        <rule name="DynamicContent">
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="True" />
          </conditions>
          <action type="Rewrite" url="dist-server/index.js" />
        </rule>
      </rules>
    </rewrite>

    <security>
      <requestFiltering>
        <hiddenSegments>
          <remove segment="bin" />
        </hiddenSegments>
      </requestFiltering>
    </security>

    <httpErrors existingResponse="PassThrough" />

    <iisnode
      node_env="%node_env%"
      nodeProcessCommandLine="node"
      interceptor="&quot;%programfiles%\iisnode\interceptor.js&quot;"
      watchedFiles="*.js;node_modules\*;routes\*.js" />

  </system.webServer>
</configuration>
